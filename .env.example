# Environment template for the Docker Compose stack (docker/compose/docker-compose.yml).
#
# Copy to .env at the repo root and fill in real values:
#   cp .env.example .env
#
# These variables configure the explorer-api and explorer-worker containers.
# The stack expects an existing Postgres reachable on the external Docker network
# `postgresql-network` (this backend connects to an existing database; it does not
# create one).

# --- shared ---
# Connection string to the explorer Postgres database.
EXPLORER_DATABASE_URL=postgres://postgres:postgres@postgres:5432/explorer
# RPC/worker label and chain selector (the DB has `main` and `main-generation-1`).
EXPLORER_NEXUS=mainnet
EXPLORER_CHAIN=main

# --- explorer-api ---
# Bind to 0.0.0.0 inside the container so the published port is reachable from the
# host (the code defaults to localhost, which is unreachable across the container
# boundary).
EXPLORER_BIND_ADDR=0.0.0.0:9000
# Host port published for the API (maps to container port 9000).
API_PORT=9000

# --- explorer-worker ---
# Node JSON-RPC endpoint(s), comma-separated for round-robin.
EXPLORER_RPC_ENDPOINTS=http://node:5172/rpc
# Optional API key sent as the `X-Api-Key` header to a rate-limited node (maps the
# worker to its key tier). Leave unset for an anonymous client.
# EXPLORER_RPC_API_KEY=
# Optional CoinGecko key for the price feed (the free tier works without it).
# EXPLORER_COINGECKO_API_KEY=

# --- compose ---
# Suffix for image/container/network names (e.g. local, staging, prod).
DEPLOY_ENV=local
